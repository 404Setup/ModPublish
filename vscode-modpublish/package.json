{
  "name": "modpublish-vsc",
  "displayName": "Minecraft Mod Publish Utils for vsc",
  "description": "Quickly publish your Minecraft mods to multiple mod hosting sites from VS Code.",
  "version": "1.12.1",
  "preview": true,
  "publisher": "404Setup",
  "sponsor": {
    "url": "https://www.patreon.com/c/tranic"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/404Setup/ModPublish.git"
  },
  "license": "LGPL-3.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "minecraft",
    "mod",
    "publisher"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "modpublish.publish",
        "title": "%modpublish.publish.title%"
      },
      {
        "command": "modpublish.setToken",
        "title": "%modpublish.setToken.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "modpublish.publish",
          "when": "resourceExtname == .jar || resourceExtname == .litemod",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "modpublish.publish",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "ModPublish",
      "properties": {
        "modpublish.modrinth.modid": {
          "type": "string",
          "default": "",
          "description": "Modrinth Project ID/Slug for this workspace.",
          "scope": "resource"
        },
        "modpublish.modrinth.token": {
          "type": "string",
          "default": "",
          "description": "Modrinth API Token.",
          "scope": "resource"
        },
        "modpublish.curseforge.modid": {
          "type": "string",
          "default": "",
          "description": "CurseForge Project ID for this workspace.",
          "scope": "resource"
        },
        "modpublish.curseforge.token": {
          "type": "string",
          "default": "",
          "description": "CurseForge API Token (Upload API).",
          "scope": "resource"
        },
        "modpublish.curseforge.studioToken": {
          "type": "string",
          "default": "",
          "description": "CurseForge Studio API Token (Mod Info API).",
          "scope": "resource"
        },
        "modpublish.github.repo": {
          "type": "string",
          "default": "",
          "description": "GitHub Repository in owner/repo format (e.g. 404Setup/ModPublish).",
          "scope": "resource"
        },
        "modpublish.github.branch": {
          "type": "string",
          "default": "",
          "description": "GitHub target branch for releasing/publishing.",
          "scope": "resource"
        },
        "modpublish.github.token": {
          "type": "string",
          "default": "",
          "description": "GitHub API Token.",
          "scope": "resource"
        },
        "modpublish.gitlab.repo": {
          "type": "string",
          "default": "",
          "description": "GitLab Project Path or Numeric ID.",
          "scope": "resource"
        },
        "modpublish.gitlab.branch": {
          "type": "string",
          "default": "",
          "description": "GitLab target branch for releasing/publishing.",
          "scope": "resource"
        },
        "modpublish.gitlab.token": {
          "type": "string",
          "default": "",
          "description": "GitLab API Token.",
          "scope": "resource"
        },
        "modpublish.generate-forge-update.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic Forge update JSON generation.",
          "scope": "application"
        },
        "modpublish.generate-forge-update.split": {
          "type": "boolean",
          "default": false,
          "description": "Split Forge update JSON by version.",
          "scope": "application"
        },
        "modpublish.common.versionFormat": {
          "type": "string",
          "default": "",
          "description": "Common version format pattern (e.g. {version}).",
          "scope": "resource"
        },
        "modpublish.common.releaseChannel": {
          "type": "string",
          "default": "release",
          "description": "Default release channel for publishing.",
          "scope": "resource"
        },
        "modpublish.common.dependencies": {
          "type": "array",
          "default": [],
          "description": "Saved project dependencies list.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "rolldown -c rolldown.config.mjs",
    "watch": "rolldown -c rolldown.config.mjs -w",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.125.0",
    "@types/yauzl": "^3.4.0",
    "rolldown": "^1.1.3",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "yauzl": "^3.4.0"
  }
}
